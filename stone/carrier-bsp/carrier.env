# Carrier-BSP env consumed by stone-provision-tegraflash.sh.
#
# The directory containing this file is overlaid on top of the MACHINE-baked
# tegraflash-bsp/ at provision time — drop replacement BSP files (DTB, BCT
# pinmux dtsi, BPF DTB, etc.) alongside this env to swap them in by name.
#
# All variables are optional. When unset, the MACHINE-baked defaults apply
# unchanged.

# CARRIER_LABEL: human-readable carrier ID for provisioning logs.
CARRIER_LABEL="jetson-agx-orin-devkit (P3737-0000 + P3701-0000)"

# CARRIER_DTB: kernel DTB filename to flash. Must exist in the merged BSP
# (either supplied by this carrier overlay or already present in the
# MACHINE-baked tegraflash-bsp/). When unset, the MACHINE-baked
# KERNEL_DEVICETREE selection wins.
# CARRIER_DTB=

# CARRIER_BPF_DTB: BPMP DTB filename. Same merge semantics as CARRIER_DTB.
# CARRIER_BPF_DTB=

# CARRIER_PINMUX_DTSI: BCT pinmux dtsi filename. Same merge semantics.
# CARRIER_PINMUX_DTSI=

# CARRIER_ODMDATA: ODMDATA hex string for UPHY lane mapping. When set,
# .env.initrd-flash's ODMDATA is rewritten before initrd-flash runs.
# CARRIER_ODMDATA=

# CARRIER_KERNEL_ARGS_APPEND: kernel cmdline tokens to append at flash time.
# CARRIER_KERNEL_ARGS_APPEND=
